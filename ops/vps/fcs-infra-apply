#!/usr/bin/env bash
set -euo pipefail

RELEASE_ROOT="/opt/fcs-infra/releases"
K3S_MANIFEST_DIR="/var/lib/rancher/k3s/server/manifests"
K3S_MANIFEST_TARGET="$K3S_MANIFEST_DIR/fcs-traefik-internal.yaml"
COOLIFY_DYNAMIC_DIR="/data/coolify/proxy/dynamic"
COOLIFY_DYNAMIC_TARGET="$COOLIFY_DYNAMIC_DIR/fcs-k3s.yaml"

die() {
  echo "fcs-infra-apply: $*" >&2
  exit 1
}

[[ "$EUID" -eq 0 ]] || die "must run as root"
[[ "$#" -eq 1 ]] || die "usage: fcs-infra-apply /opt/fcs-infra/releases/<40-char-sha>"

release="$1"
[[ "$release" =~ ^${RELEASE_ROOT}/[a-f0-9]{40}$ ]] || die "invalid release path"
[[ -d "$release" ]] || die "release does not exist"
[[ "$(realpath -e -- "$release")" == "$release" ]] || die "release must be a real directory"

for command in kubectl systemctl docker install realpath find python3; do
  command -v "$command" >/dev/null 2>&1 || die "missing command: $command"
done

required_files=(
  "$release/k8s/vps/traefik-internal.yaml"
  "$release/k8s/vps/deploy-infra.sh"
  "$release/k8s/vps/coolify-fcs-k3s.yaml"
  "$release/k8s/vps/realm/conexao-solidaria-realm.json"
)
for file in "${required_files[@]}"; do
  [[ -f "$file" && ! -L "$file" ]] || die "required release file is missing or a symlink: $file"
done

find "$release" -xdev -type l -print -quit | grep -q . && die "release contains symlinks"

python3 -m json.tool "$release/k8s/vps/realm/conexao-solidaria-realm.json" >/dev/null || die "invalid realm JSON"
systemctl is-active --quiet k3s || die "k3s is not active"
[[ "$(docker inspect --format '{{.State.Running}}' coolify-proxy 2>/dev/null || true)" == "true" ]] || die "coolify-proxy is not running"

# The release is immutable after this point. The SSH user owns the upload
# directory, so take ownership before executing any release-controlled script.
chown -R root:root -- "$release"
find "$release" -xdev -type d -exec chmod 0755 {} +
find "$release" -xdev -type f -exec chmod go-w {} +

install -D -o root -g root -m 0600 \
  "$release/k8s/vps/traefik-internal.yaml" \
  "$K3S_MANIFEST_TARGET"

for _ in $(seq 1 60); do
  if kubectl -n fcs-platform get deployment fcs-traefik-internal >/dev/null 2>&1; then
    break
  fi
  sleep 5
done
kubectl -n fcs-platform get deployment fcs-traefik-internal >/dev/null 2>&1 \
  || die "internal Traefik deployment was not created"
kubectl -n fcs-platform rollout status deployment/fcs-traefik-internal --timeout=300s

KUBECTL="$(command -v kubectl)" bash "$release/k8s/vps/deploy-infra.sh" \
  "$release/k8s/vps/realm/conexao-solidaria-realm.json"

install -d -o root -g root -m 0700 "$COOLIFY_DYNAMIC_DIR"
install -o 9999 -g root -m 0600 \
  "$release/k8s/vps/coolify-fcs-k3s.yaml" \
  "$COOLIFY_DYNAMIC_TARGET"

echo "fcs-infra release applied: $release"
kubectl get nodes --no-headers
kubectl -n fcs-infra get pods,pvc,ingress --no-headers
kubectl -n fcs-identity get deployment,service,ingress --no-headers
