{
  "title": "FCS Identity - VPS K3s",
  "description": "Métricas reais do deployment fcs-identity coletadas pelo Datadog Agent no K3s.",
  "layout_type": "ordered",
  "is_read_only": false,
  "widgets": [
    {
      "definition": {
        "title": "CPU dos pods",
        "type": "timeseries",
        "requests": [
          {
            "q": "avg:kubernetes.cpu.usage.total{kube_cluster_name:fcs-vps-k3s,kube_namespace:fcs-identity} by {pod_name}",
            "display_type": "line"
          }
        ],
        "show_legend": true,
        "yaxis": {
          "include_zero": true,
          "scale": "linear",
          "label": "cores"
        }
      }
    },
    {
      "definition": {
        "title": "Memória dos pods",
        "type": "timeseries",
        "requests": [
          {
            "q": "avg:kubernetes.memory.working_set{kube_cluster_name:fcs-vps-k3s,kube_namespace:fcs-identity} by {pod_name}",
            "display_type": "line"
          }
        ],
        "show_legend": true,
        "yaxis": {
          "include_zero": true,
          "scale": "linear",
          "label": "bytes"
        }
      }
    },
    {
      "definition": {
        "title": "Réplicas disponíveis",
        "type": "query_value",
        "requests": [
          {
            "q": "sum:kubernetes_state.deployment.replicas_available{kube_cluster_name:fcs-vps-k3s,kube_namespace:fcs-identity,kube_deployment:fcs-identity}",
            "aggregator": "last"
          }
        ],
        "autoscale": true,
        "precision": 0,
        "text_align": "center"
      }
    }
  ]
}
