GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Datadog forwarding is disabled in the default compose file.
# To enable it, set ENABLE_DATADOG_EXPORT=true, fill DD_API_KEY, and include
# docker-compose.datadog.yml in the docker compose command.
ENABLE_DATADOG_EXPORT=false
DD_API_KEY=
DD_SITE=datadoghq.com
